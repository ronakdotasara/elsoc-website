# ──────────────────────────────────────────────────────────────────────────────
# ELSOC website — environment template
# Copy to `.env` and fill in. Every variable is optional in development:
# the site falls back to bundled seed content when a service is not configured.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Postgres + pgvector) ───────────────────────────────────────────
# Local (docker compose):  postgresql://elsoc:elsoc@localhost:5432/elsoc
# Neon / Supabase:         copy the pooled connection string from the dashboard
DATABASE_URL="postgresql://elsoc:elsoc@localhost:5432/elsoc"

# ── Auth.js (admin login) ─────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=""
# Base URL of the deployment (needed behind proxies, e.g. https://elsoc.nith.ac.in)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Used ONCE by `prisma db seed` to create the admin account (stored as a bcrypt
# hash — the plaintext never lives in the database or the repo).
ADMIN_USERNAME="elsocadmin"
ADMIN_SEED_PASSWORD="elsoc@123"

# ── AI assistant (optional) ───────────────────────────────────────────────────
# Without a key the assistant runs in offline mode (retrieval-based answers).
ANTHROPIC_API_KEY=""
# Model used for chat responses.
ELSOC_CHAT_MODEL="claude-haiku-4-5-20251001"

# ── Object storage for admin uploads (optional) ───────────────────────────────
# When unset, uploads are written to ./public/uploads (fine for self-hosting).
BLOB_READ_WRITE_TOKEN=""

# ── Secret used by the admin panel to trigger on-demand ISR revalidation ─────
REVALIDATE_SECRET=""
